{
  "rules": {
    "users": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('users').child(auth.uid).child('role').val() === 'AJS')",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('users').child(auth.uid).child('role').val() === 'AJS')",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('users').child(auth.uid).child('role').val() === 'AJS')"
      }
    },
    "flights": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "pernocte": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "diferidos": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "routeAfectaciones": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "limpiezaChecklist": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
